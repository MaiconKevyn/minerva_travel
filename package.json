{
  "name": "minerva-travel",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "workspaces": [
    "frontend_atual/apps/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace minerva-travel-frontend",
    "build": "npm run build --workspace minerva-travel-frontend && rm -rf dist && cp -R frontend_atual/apps/web/dist ./dist",
    "start": "npm run start --workspace minerva-travel-frontend",
    "lint": "npm run lint --workspace minerva-travel-frontend",
    "test": "npm run test --workspace minerva-travel-frontend"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "overrides": {
    "esbuild": "0.27.2"
  }
}
