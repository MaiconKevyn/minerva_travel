IMAGE_PROVIDER=replicate
LANDMARK_ART_GENERATION=false
# Aquarela dos pontos turisticos a partir da foto real (flux-kontext), com
# cache global por place_id em runtime/landmark-art + bucket landmark-assets.
LANDMARK_STYLIZED_ART=true
COLORING_LINEART_GENERATION=true
OPENAI_API_KEY=
OPENAI_LANDMARK_MODEL=gpt-4o-2024-08-06
GOOGLE_MAPS_API_KEY=
REPLICATE_API_TOKEN=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_AUDIENCE=authenticated
APP_ENV=development
AUTH_REQUIRED=true
# Obrigatorios como true em producao; false preserva o fluxo local legado.
REQUEST_CONTROL_ENABLED=false
REQUEST_CONTROL_FAIL_CLOSED=true
REQUEST_CONTROL_DB_PATH=runtime/request-control.sqlite3
IDEMPOTENCY_KEY_REQUIRED=false
IDEMPOTENCY_PENDING_TTL_SECONDS=900
IDEMPOTENCY_TTL_SECONDS=86400
RATE_LIMIT_GUIDE_GENERATE_USER=2
RATE_LIMIT_GUIDE_GENERATE_IP=5
RATE_LIMIT_GUIDE_GENERATE_WINDOW_SECONDS=600
QUOTA_GUIDE_GENERATE_USER=20
QUOTA_GUIDE_GENERATE_PERIOD_SECONDS=86400
CONCURRENCY_USER_LIMIT=2
CONCURRENCY_GUIDE_GENERATE_USER_LIMIT=1
CONCURRENCY_PROVIDER_REPLICATE_LIMIT=2
CONCURRENCY_PROVIDER_OPENAI_LIMIT=4
CONCURRENCY_PROVIDER_GOOGLE_LIMIT=8
CONCURRENCY_LEASE_SECONDS=900
GUIDE_RETENTION_DAYS=30
GUIDE_DRAFT_RETENTION_DAYS=14
PHOTO_PROCESSING_CONSENT_REQUIRED=true
PILOT_RESTAURANT_RECOMMENDATIONS_ENABLED=true
ASYNC_GUIDE_JOBS_ENABLED=false
GUIDE_JOB_MAX_ATTEMPTS=3
IMAGE_GENERATION_CONCURRENCY=2
IMAGE_UPLOAD_MAX_BYTES=10485760
IMAGE_UPLOAD_MAX_PIXELS=40000000
IMAGE_UPLOAD_MAX_WIDTH=12000
IMAGE_UPLOAD_MAX_HEIGHT=12000
OBSERVABILITY_HASH_SALT=
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SUPABASE_STORAGE_ENABLED=true
SUPABASE_BUCKET_LANDMARK_ASSETS=landmark-assets
FRONTEND_BASE_URL=http://127.0.0.1:3000
